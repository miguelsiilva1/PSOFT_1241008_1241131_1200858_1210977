@startuml
title View Aircraft's details by Registration Number — GET /aircraft

autoactivate on

actor "Backoffice\nOperator/ATCC" as BOATCC
participant AircraftController
participant FindAircraftByRegistrationNumberUseCase <<@UseCase>>
participant AircraftRepository
participant AircraftAssembler

BOATCC -> AircraftController : GET /aircraft\n{\n\tregistration_number: "N737UA"\n}

AircraftController -> AircraftController : extract username from JWT
alt "User has authorization"
    AircraftController -> FindAircraftByRegistrationNumberUseCase : execute(registration_number)
        FindAircraftByRegistrationNumberUseCase -> AircraftRepository : findByRegistrationNumber(registration_number)
        alt "The aircraft exists"
        AircraftRepository --> FindAircraftByRegistrationNumberUseCase : aircraft_object
        FindAircraftByRegistrationNumberUseCase -> AircraftAssembler : toModel(aircraft_object)
        AircraftAssembler --> FindAircraftByRegistrationNumberUseCase : aircraft_dto
    FindAircraftByRegistrationNumberUseCase --> AircraftController : aircraft_dto
AircraftController --> BOATCC : 200 OK\n{ aircraft's details, _links.return }
        else "The aircraft does not exist in the system"
AircraftController --> BOATCC : 400 Bad Request\n{ message: "The request's data is malformed" }
        end

else "User does not have authorization"
AircraftController --> BOATCC : 401 Unauthorized\n{ message: "The user does not have valid credentials for this action" }
end

@enduml