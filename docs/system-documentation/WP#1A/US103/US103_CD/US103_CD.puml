@startuml
'https://plantuml.com/class-diagram

@startuml
'https://plantuml.com/class-diagram

title View Aircraft's details by Registration Number: Architecture — Class Diagram

package "Aircraft Aggregate" <<rectangle>> {
    class Aircraft <<Aggregate Root>> {
        - AircraftRegistration registration_number
        - AircraftManufacturer manufacturer
        - AircraftModel model
        - SeatingConfiguration seating_configuration
        - Date manufactoring_date
        - Date last_maintenance
        - int days_since_last_maintenance
        - int max_flight_hours_until_maintenance
        - int max_days_until_maintenance
        - AircraftStatus status
        - String image
        ---
        + Aircraft(aircraft_registration, aircraft_model, manufacturing_date, last_maintenance, max_flight_hours_until_maintenance, max_days_until_maintenance, seating_configuration, status)
    }
    interface AircraftRepository {
        + Aircraft findByRegistrationNumber(registration_number)
    }
    class FindAircraftByRegistrationNumberUseCase <<@UseCase>> {
        + Aircraft execute(registration_number)
    }

    FindAircraftByRegistrationNumberUseCase ..> AircraftRepository : findByRegistrationNumber()
}

@enduml

@enduml