@startuml
title Update Airport Status — PATCH /api/airports/{iata}

autoactivate on

actor "Backoffice Operator" as BO
participant AirportController
participant UpdateAirportStatusUseCase <<@UseCase>>
participant UpdateAirportService <<Domain Service>>
participant Airport
participant AirportRepository

BO -> AirportController : PATCH /api/airports/{iata}


AirportController -> AirportController : extract username from JWT
return
alt "User has authorization"
    AirportController -> UpdateAirportStatusUseCase : execute(iata_code, status)
        UpdateAirportStatusUseCase -> AirportRepository : findByIata(iata_code)

        alt "The airport exists"
            AirportRepository --> UpdateAirportStatusUseCase :

            UpdateAirportStatusUseCase -> UpdateAirportService : updateStatus(airport, status)
                UpdateAirportService -> Airport : updateStatus(status)
                return
            return airport (updated)

            UpdateAirportStatusUseCase -> AirportRepository : save(airport)
            return airport (persisted)

            UpdateAirportStatusUseCase --> AirportController : airport
            AirportController --> BO : 200 OK

        else "The airport does not exist"

            AirportController --> BO : 400 Bad Request\n{ message: "The request's data is malformed" }
        end

else "User does not have authorization"
    AirportController --> BO : 403 Forbidden
end

@enduml