@startuml
'https://plantuml.com/class-diagram

title Add Airplane Certification to Airport: Architecture — Class Diagram

package "Airport Aggregate" <<rectangle>> {
    class Airport <<root>> {
        - Set<Aircraft> certified_aircrafts
        ---
    }

    interface AirportRepository {
        + Optional<Airport> findByIataCode(LocationIdentifier iata_code)
        + Airport save(Airport airport)
    }
}

package "Aircraft Aggregate" <<rectangle>> {
    class Aircraft <<root>> {
        - AircraftRegistration registration_number
        ---
    }

    class AircraftRegistration <<value object>> {
        - String registration_number
    }

    interface AircraftRepository {
        + Optional<Aircraft> findByRegistrationNumber(AircraftRegistration registration)
    }
}

class CertifyAircraftService <<Domain Service>> {
    + void certify(Airport airport, Aircraft aircraft)
}

class CertifyAircraftUseCase <<@UseCase>> {
    + Airport execute(LocationIdentifier iata_code, String registration_number)
}

CertifyAircraftUseCase ..> AirportRepository : findByIataCode()\nsave()
CertifyAircraftUseCase ..> AircraftRepository : findByRegistrationNumber()
CertifyAircraftUseCase ..> CertifyAircraftService : delegates to >
CertifyAircraftService ..> Airport : modifies >

@enduml