@startuml
title View Scheduled Flights for Aircraft — GET /api/flights/aircraft/{registration}

autoactivate on

actor "ATCC" as ATCC
participant FlightController
participant ViewAircraftFlightsUseCase <<@UseCase>>
participant AircraftRepository
participant FlightRepository

ATCC -> FlightController : GET /api/flights/aircraft/{registration}

FlightController -> FlightController : extract username from JWT

alt "User has authorization"
    FlightController -> ViewAircraftFlightsUseCase : execute(aircraft_registration)

    ViewAircraftFlightsUseCase -> AircraftRepository : findByRegistrationNumber(aircraft_registration)

    alt "The aircraft exists"
        AircraftRepository --> ViewAircraftFlightsUseCase : aircraft

        ViewAircraftFlightsUseCase -> FlightRepository : findByAircraftOrderByScheduledDepartureAsc(aircraft)
        FlightRepository --> ViewAircraftFlightsUseCase : scheduled_flights

        ViewAircraftFlightsUseCase --> FlightController : scheduled_flights
        FlightController --> ATCC : 200 OK

    else "The aircraft does not exist"
        FlightController --> ATCC : 404 Not Found\n{ message: "Aircraft not found." }
    end

else "User does not have authorization"
    FlightController --> ATCC : 401 Unauthorized\n{ message: "The user does not have valid credentials for this action" }
end

@enduml