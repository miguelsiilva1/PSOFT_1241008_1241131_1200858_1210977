@startuml
autonumber
skinparam maxMessageSize 150
title US119: Complete Maintenance Record - Sequence Diagram

autoactivate on

actor "Maintenance Technician" as User
participant "MaintenanceController" as Controller <<RestController>>
participant "CompleteMaintenanceRecordUseCase" as UseCase <<UseCase>>
participant "MaintenanceServiceImpl" as Service <<Domain Service>>
participant "MaintenanceRecordRepository" as RecRepo <<Repository>>
participant "AircraftRepository" as AirRepo <<Repository>>

User -> Controller : PATCH /api/maintenance/records/{recordId}/complete\n(CompleteMaintenanceRecordRequest)

Controller -> Controller : validate JWT and authority (MAINTENANCE_TECH)
return

Controller -> UseCase : execute(recordId, request.completion_notes)

UseCase -> Service : completeMaintenanceRecord(recordId, completionNotes)

Service -> RecRepo : findById(recordId)
return record (validate existence)

Service -> Service : record.complete(completionNotes)
return

Service -> RecRepo : save(record)
return savedRecord

Service -> Service : aircraft.setStatus(AVAILABLE)
return

Service -> AirRepo : save(aircraft)
return updatedAircraft

return savedRecord

return savedRecord

Controller -> Controller : map to MaintenanceRecordResponse\n& build HATEOAS links
return

return 200 OK (MaintenanceRecordResponse)

@enduml