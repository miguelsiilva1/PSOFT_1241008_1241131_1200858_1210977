return aircraft (validate existence)

Service -> RecRepo : totalMaintenanceHoursByAircraftRegistrationNumber(registrationNumber)
return totalHours (Double)

return totalHours

return totalHours

Controller -> Controller : map to MaintenanceHoursResponse\n& build HATEOAS links
return

return 200 OK (EntityModel<MaintenanceHoursResponse>)

