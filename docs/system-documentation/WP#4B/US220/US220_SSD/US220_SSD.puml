@startuml
title Generate Maintenance Cost Report — System Sequence Diagram

autoactivate on

actor "ATCC" as ATCC
participant "System" as System

ATCC -> System : GET /api/maintenance/reports/costs\n?aircraft={registration}&model={modelName}

alt "Report successfully generated"
    System --> ATCC : 200 OK\n{ filterType, filterValue, totalCost, totalInterventions }

else "User does not have authorization"
    System --> ATCC : 401 Unauthorized\n{ message: "The user does not have valid credentials for this action" }
end

@endif