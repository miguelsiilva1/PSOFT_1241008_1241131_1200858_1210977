@startuml
'https://plantuml.com/class-diagram
hide circle
skinparam classAttributeIconSize 0
hide methods

package "Aircraft Aggregate" {
    class NonEmptyString <<value object>> {
        - string: String
    }
    class PositiveDouble <<value object>> {
        - number: double
    }
    class Aircraft <<entity>> <<root>> {
        - number_of_seats: PositiveInteger
        - manufacturing_date: Date
        - image: BufferedImage
        - last_maintenance: Date
        - days_since_last_maintenance <<calculated>>: PositiveInteger
        - max_flight_hours_until_maintenance: PositiveInteger
        - max_days_until_maintenance: PositiveInteger
    }
    Aircraft o--> AircraftRegistration
    Aircraft o--> AircraftStatus
    Aircraft o--> AircraftManufacturer
    Aircraft o--> "3" PositiveDouble
    Aircraft o--> "N" NonEmptyString

    class AircraftManufacturer <<value object>> {
        - manufacturer: String
    }
    class AircraftRegistration <<value object>> {
        - registration_number: String
    }
    class AircraftStatus <<enum>> {
        - AVAILABLE: int
        - IN_FLIGHT: int
        - INACTIVE: int
        - UNDER_MAINTENANCE: int
    }
}

package "Airport Aggregate" {
    class NonEmptyString <<value object>> {
        - string: String
    }
    class PositiveDouble <<value object>> {
        - number: double
    }
    class Airport <<entity>> <<root>> {
        - images: List<String>
    }
    Airport o--> LocationIdentifier
    Airport o--> Coordinates
    Airport o--> "N" RunwayInfo
    Airport o--> AirportStatus
    Airport o--> TimeZone
    Airport o--> "N" NonEmptyString
    Airport o--> OperationalHours
    Airport o--> "N" ContactInfo
    Airport o--> AirportType

    class AirportType <<value object>> {
        - name: String
        - description: String
    }
    class LocationIdentifier <<value object>> {
        - iata_code: String
    }
    class TimeZone <<entity>> {
        - abbreviation: NonEmptyString
        - utc_offset_minutes: PositiveInteger
        - gmt_offset_minutes: PositiveInteger
    }
    class OperationalHours <<value object>> {
        - opening_hours: PositiveInteger
        - closing_hours: PositiveInteger
    }
    class ContactInfoType <<enum>> {
        - EMAIL: int
        - PHONE_NUMBER: int
        - FAX_NUMBER: int
        - WEBSITE: int
        - MAILING_ADDRESS: int
    }
    class ContactInfo <<value object>> {
        - type: String
        - contact: String
        - description: String
    }
    ContactInfo o--> ContactInfoType
    class Coordinates <<value object>> {
        - longitude: double
        - longitude_direction: char
        - latitude: double
        - latitude_direction: char
    }
    class Orientation <<value object>> {
        - orientation: String
    }
    class RunwayInfo <<entity>> {

    }
    RunwayInfo o--> NonEmptyString
    RunwayInfo o--> PositiveDouble
    RunwayInfo o--> Orientation
    class AirportStatus <<enum>> {
        - OPERATIONAL: int
        - CLOSED: int
        - UNDER_MAINTENANCE: int
    }
}

package "Route Aggregate" {
    class PositiveDouble <<value object>>  {
        - number: double
    }
    class Route <<entity>> <<root>>{
        - active: boolean
    }
    Route o--> RouteID
    Route o--> "4" PositiveDouble

    class RouteID <<value object>> {
        - id: String
    }
}

package "Flight Aggregate" {
    class Flight <<entity>> <<root>> {
        - scheduled_datetime: Date
        - delayed_hours: PositiveDouble
    }
    Flight o--> FlightStatus
    Flight o--> FlightID

    class FlightStatus <<enum>> {
        - SCHEDULED: int
        - OCCURRING: int
        - DELAYED: int
        - COMPLETED: int
        - CANCELED: int
    }
    class FlightID <<value object>> {
        - id: String
    }
}

package "Maintenance Aggregate" {
    class NonEmptyString <<value object>> {
        - string: String
    }
    class PositiveDouble <<value object>> {
        - number: double
    }
    class PartNumber <<value object>> {
        - part_number: String
    }
    class MaintenanceTemplateType <<enum>> {
        - INSPECTION: int
        - SCHEDULED_MAINTENANCE: int
        - OVERHAUL: int
        - MODIFICATION: int
    }
    class NumberedItem <<entity>> {
        - id: PositiveInteger
    }
    NumberedItem o--> NonEmptyString

    class MaintenanceTemplate <<entity>> {
        - applicable_models: Set<String>
    }
    MaintenanceTemplate o--> MaintenanceTemplateType
    MaintenanceTemplate o--> NonEmptyString
    MaintenanceTemplate o--> "N" NumberedItem
    MaintenanceTemplate o--> MaintenanceComponent
    MaintenanceTemplate o--> PositiveDouble

    class MaintenanceComponent <<enum>> {
        - ENGINE: int
        - AIRFRAME: int
        - AVIONICS: int
        - INTERIOR: int
        - EXTERIOR: int
    }

    class MaintenancePart <<entity>> {
        - description: String
        - stock_quantity: PositiveInteger
    }
    MaintenancePart o--> MaintenanceComponent
    MaintenancePart o--> NonEmptyString
    MaintenancePart o--> PartNumber

    class MaintenanceRecord <<entity>> <<root>> extends MaintenanceTemplate {
        - start_date: Date
        - end_date <<calculated>>: Date
        - completed: boolean
    }
    MaintenanceRecord ---> MaintenanceCompletionNotes
    MaintenanceRecord o--> NonEmptyString
    MaintenanceRecord o--> PositiveDouble
    class MaintenanceCompletionNotes <<value object>> {
        - completion_notes: String
    }
}

Airport -up> "N" Aircraft
Route --> "2" Airport
MaintenanceRecord --> Aircraft
Flight --> Route
Flight --> Aircraft

@enduml